      "default": "optional",
      "installMode": "symlink",
      "targetDir": "~/.openclaw/workspace/skills",
      "adapter": "../../adapters/openclaw/adapter.md"
    },
    {
      "id": "opencode",
      "label": "opencode",
      "default": "optional",
      "installMode": "symlink",
      "targetDir": "~/.opencode/skills",
      "adapter": "../../adapters/opencode/adapter.md"
    },
    {
      "id": "antigravity",
      "aliases": ["antigravity-cli"],
