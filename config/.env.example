# Shared migration settings for the active skills repository.
# Leave secrets empty and fill them locally on each machine.

# Override when the skills repo is not discovered from its own checkout path.
AI_SKILLS_HOME=

# Target user home for Codex/Claude/Junie/Agents/Hermes skill wiring.
AI_HOST_HOME=

# Required by kingdee-cosmic and kingdee-metadata-analyzer.
# Expected layout: $AI_KNOWLEDGE_ROOT/kingdee/cosmic/projects/config-table.md
AI_KNOWLEDGE_ROOT=

# Optional override for darwin-skill when Playwright is not available via normal Node resolution.
# Multiple entries can be separated with ":" on macOS/Linux.
DARWIN_PLAYWRIGHT_CANDIDATES=

# Optional web-access overrides.
WEB_ACCESS_BROWSER_PATH=
WEB_ACCESS_CDP_HOST=127.0.0.1
WEB_ACCESS_CDP_PORT=9222

# Optional YouTube cookie file for union-search-skill download flows.
YTDLP_COOKIES_FILE=
