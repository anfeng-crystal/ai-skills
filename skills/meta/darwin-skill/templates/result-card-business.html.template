<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>$skill_name 优化成果报告</title>
  <style>
    :root {
      --bg-primary: #ffffff;
      --bg-secondary: #f8f9fa;
      --bg-tertiary: #e9ecef;
      --text-primary: #212529;
      --text-secondary: #6c757d;
      --text-muted: #adb5bd;
      --accent: #0066cc;
      --accent-secondary: #0052a3;
      --border: #dee2e6;
      --success: #28a745;
      --warning: #ffc107;
      --shadow: rgba(0, 0, 0, 0.1);

      --font-display: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans SC', sans-serif;
      --font-body: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans SC', sans-serif;
      --font-mono: 'SF Mono', 'Monaco', 'Consolas', monospace;

      --title-size: clamp(2rem, 4vw, 2.8rem);
      --subtitle-size: clamp(1.3rem, 2.5vw, 1.6rem);
      --body-size: clamp(0.95rem, 1.5vw, 1.05rem);
      --small-size: clamp(0.85rem, 1.2vw, 0.9rem);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: var(--bg-primary);
      color: var(--text-primary);
      font-family: var(--font-body);
      padding: clamp(1.5rem, 4vw, 4rem);
      line-height: 1.7;
    }

    .container {
      max-width: 1000px;
      margin: 0 auto;
    }

    header {
      margin-bottom: 3rem;
      padding-bottom: 2rem;
      border-bottom: 3px solid var(--accent);
    }

    h1 {
      font-size: var(--title-size);
      color: var(--accent);
      font-weight: 700;
      margin-bottom: 0.75rem;
      font-family: var(--font-display);
      letter-spacing: -0.02em;
    }

    .subtitle {
      font-size: var(--body-size);
      color: var(--text-secondary);
      font-weight: 400;
    }

    .meta {
      color: var(--text-secondary);
      font-size: var(--small-size);
      display: flex;
      gap: 2rem;
      flex-wrap: wrap;
      margin-top: 1rem;
    }

    .meta-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .meta-label {
      font-weight: 600;
      color: var(--text-primary);
    }

    .card {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: clamp(1.5rem, 3vw, 2.5rem);
      margin-bottom: 2rem;
      box-shadow: 0 2px 8px var(--shadow);
    }

    h2 {
      font-size: var(--subtitle-size);
      color: var(--text-primary);
      margin-bottom: 1.5rem;
      font-weight: 600;
      padding-bottom: 0.75rem;
      border-bottom: 2px solid var(--border);
    }

    .score-container {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 2rem;
      padding: 2rem 0;
      flex-wrap: wrap;
    }

    .score-box {
      text-align: center;
      padding: 1.5rem 2rem;
      background: var(--bg-primary);
      border-radius: 8px;
      border: 2px solid var(--border);
    }

    .score-label {
      font-size: var(--small-size);
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
      font-weight: 600;
    }

    .score {
      font-size: clamp(2.5rem, 5vw, 3.5rem);
      color: var(--accent);
      font-weight: 700;
      line-height: 1;
      font-family: var(--font-mono);
    }

    .arrow {
      font-size: clamp(1.5rem, 3vw, 2rem);
      color: var(--text-secondary);
    }

    .delta-box {
      background: var(--success);
      color: white;
      border: none;
    }

    .delta {
      color: white;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: var(--body-size);
      background: var(--bg-primary);
      border-radius: 8px;
      overflow: hidden;
    }

    th, td {
      padding: 1rem 1.25rem;
      text-align: left;
    }

    th {
      background: var(--bg-tertiary);
      color: var(--text-primary);
      font-weight: 600;
      text-transform: uppercase;
      font-size: var(--small-size);
      letter-spacing: 0.05em;
    }

    td {
      color: var(--text-primary);
      border-bottom: 1px solid var(--border);
    }

    tr:last-child td {
      border-bottom: none;
    }

    tr:hover td {
      background: var(--bg-secondary);
    }

    .delta-cell {
      color: var(--success);
      font-weight: 700;
      font-family: var(--font-mono);
    }

    ul {
      list-style: none;
      padding: 0;
    }

    li {
      padding: 1rem 0;
      padding-left: 2.5rem;
      position: relative;
      font-size: var(--body-size);
      border-bottom: 1px solid var(--border);
    }

    li:last-child {
      border-bottom: none;
    }

    li::before {
      content: '✓';
      position: absolute;
      left: 0;
      top: 1rem;
      width: 1.5rem;
      height: 1.5rem;
      background: var(--success);
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.8rem;
      font-weight: bold;
    }

    .test-result {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .test-id {
      color: var(--accent);
      font-family: var(--font-mono);
      font-weight: 500;
    }

    .test-status {
      color: var(--success);
      font-weight: 600;
      padding: 0.25rem 0.75rem;
      background: rgba(40, 167, 69, 0.1);
      border-radius: 4px;
    }

    .test-delta {
      color: var(--text-secondary);
      font-family: var(--font-mono);
      font-weight: 600;
    }

    footer {
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 2px solid var(--border);
      text-align: center;
      color: var(--text-secondary);
      font-size: var(--small-size);
    }

    .quote {
      font-style: italic;
      margin-bottom: 1rem;
      color: var(--text-primary);
      font-size: var(--body-size);
    }

    .link {
      color: var(--accent);
      text-decoration: none;
      font-weight: 500;
    }

    .link:hover {
      text-decoration: underline;
    }

    @media (max-width: 768px) {
      .score-container {
        flex-direction: column;
        gap: 1rem;
      }

      .score-box {
        width: 100%;
      }

      table {
        font-size: var(--small-size);
      }

      th, td {
        padding: 0.75rem;
      }
    }

    @media print {
      body {
        background: white;
      }

      .card {
        box-shadow: none;
        page-break-inside: avoid;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>$skill_name</h1>
      <p class="subtitle">Skill 优化成果报告</p>
      <div class="meta">
        <div class="meta-item">
          <span class="meta-label">优化日期:</span>
          <span>$date</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">评估模型:</span>
          <span>Claude Opus 4.7</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">优化工具:</span>
          <span>Darwin Skill v1.0</span>
        </div>
      </div>
    </header>

    <section class="card">
      <h2>分数变化</h2>
      <div class="score-container">
        <div class="score-box">
          <div class="score-label">改进前</div>
          <div class="score">$score_before</div>
        </div>
        <div class="arrow">→</div>
        <div class="score-box">
          <div class="score-label">改进后</div>
          <div class="score">$score_after</div>
        </div>
        <div class="score-box delta-box">
          <div class="score-label">提升</div>
          <div class="score delta">+$score_delta</div>
        </div>
      </div>
    </section>

    <section class="card">
      <h2>维度对比</h2>
      <table>
        <thead>
          <tr>
            <th>维度</th>
            <th>改进前</th>
            <th>改进后</th>
            <th>提升</th>
          </tr>
        </thead>
        <tbody>
          $dimensions_rows
        </tbody>
      </table>
    </section>

    <section class="card">
      <h2>关键改进</h2>
      <ul>
        $improvements_items
      </ul>
    </section>

    <section class="card">
      <h2>实测表现</h2>
      <ul>
        $test_results_items
      </ul>
    </section>

    <footer>
      <p class="quote">"Train your Skills like you train your models"</p>
      <p><a href="https://github.com/alchaincyf/darwin-skill" class="link">github.com/alchaincyf/darwin-skill</a></p>
    </footer>
  </div>
</body>
</html>
