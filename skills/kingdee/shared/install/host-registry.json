      "targetDir": "~/.codex/skills",
      "adapter": "../../adapters/codex/adapter.md"
    },
    {
      "id": "claude-code",
      "aliases": ["claude"],
      "label": "Claude Code",
      "default": "enabled",
      "installMode": "symlink",
      "targetDir": "~/.claude/skills",
      "adapter": "../../adapters/claude-code/adapter.md"
    },
    {
      "id": "hermes",
